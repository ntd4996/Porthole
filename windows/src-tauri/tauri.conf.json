{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Porthole",
  "version": "0.1.0",
  "identifier": "com.datnt.porthole",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Porthole",
        "width": 360,
        "height": 540,
        "minWidth": 360,
        "minHeight": 360,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://porthole.thenightwatcher.online/windows/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5RjYyM0UxOTY1RjVBNTUKUldSVldsK1c0U1AyZVJnMGhuMCsyR0czTEZXSFZ4UU5BWEJWeURwZ0d0Z01YL3RkWEhsRFdKYk0K"
    }
  }
}
